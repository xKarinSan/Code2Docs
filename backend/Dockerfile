FROM python:3.13

WORKDIR /backend

COPY . /backend/

RUN pip3 install python-multipart
RUN pip3 install pyjwt[crypto]
RUN pip3 install --no-cache-dir -r requirements.txt

ARG BOTO_REGION_NAME_ARG
ENV BOTO_REGION_NAME=${BOTO_REGION_NAME_ARG}

ARG BOTO_SECRET_NAME_ARG
ENV BOTO_SECRET_NAME=${BOTO_SECRET_NAME_ARG}

ARG BOTO_SECRET_KEYNAME_ARG
ENV BOTO_SECRET_KEYNAME=${BOTO_SECRET_KEYNAME_ARG}

ARG OPENAI_API_KEY_ARG
ENV OPENAI_API_KEY=${OPENAI_API_KEY_ARG}

ARG OPENAI_MODEL_ARG
ENV OPENAI_MODEL=${OPENAI_MODEL_ARG}

ARG GITHUB_CLIENT_ID_ARG
ENV GITHUB_CLIENT_ID=${GITHUB_CLIENT_ID_ARG}

ARG GITHUB_CLIENT_SECRET_ARG
ENV GITHUB_CLIENT_SECRET=${GITHUB_CLIENT_SECRET_ARG}

ARG GITHUB_APP_ID_ARG
ENV GITHUB_APP_ID=${GITHUB_APP_ID_ARG}

CMD ["uvicorn", "src.main:app", "--reload", "--port=8000", "--host=0.0.0.0"]
EXPOSE 8000